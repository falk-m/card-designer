{
  "compilerOptions": {
    "removeComments": true,
    "preserveConstEnums": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["es5", "es6", "dom"],
  },
  "include": [
    "src/**/*"
  ]
}
